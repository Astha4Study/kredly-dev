{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "api": {
      "entrypoint": "server/cmd/api/main.go",
      "routing": {
        "paths": ["/api", "/api/*"]
      },
      "routePrefix": "/api"
    },
    "web": {
      "routePrefix": "/",
      "framework": "vite"
    }
  }
}
